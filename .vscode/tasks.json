{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend API (.venv)",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": [
        "-m",
        "uvicorn",
        "cs_api_server:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend/counter_strike"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Current File (.venv)",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": [
        "${file}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": []
    }
  ]
}
