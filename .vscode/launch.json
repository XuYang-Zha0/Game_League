{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend API (.venv)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "cs_api_server:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/backend/counter_strike",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "Python: Current File (.venv)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${fileDirname}",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  ]
}
